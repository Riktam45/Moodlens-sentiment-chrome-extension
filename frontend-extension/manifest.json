{
  "manifest_version": 3,
  "name": "MoodLens",
  "version": "1.0",
  "description": "Social Media Sentiment Analyzer",

  "permissions": [
    "activeTab",
    "storage"
  ],

  "host_permissions": [
    "http://127.0.0.1:8000*"
  ],

  "action": {
    "default_popup": "popup.html"
  },

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}